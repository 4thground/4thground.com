<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="4TH GROUND Support. TVOD help for rentals, purchases, streaming, 4K playback, account and billing. Email support@4thground.com">
<link rel="canonical" href="https://4thground.com/support/">
<meta name="robots" content="index, follow">
    <title>Support - 4TH GROUND</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-black text-white">
    
    <nav class="absolute top-0 w-full z-20 bg-gradient-to-b from-black/80 to-transparent">
        <div class="max-w-7xl mx-auto px-6 py-6 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3">
                <img src="/logo.png" alt="4TH GROUND" class="h-8">
            </a>
            <div class="flex gap-4 md:gap-8 text-xs md:text-sm font-medium">
                <a href="/" class="text-zinc-300 hover:text-white">Home</a>
                <a href="/about/" class="text-zinc-300 hover:text-white">About</a>
                <a href="/services/" class="text-zinc-300 hover:text-white">Services</a>
                <a href="/team/" class="text-zinc-300 hover:text-white">Team</a>
                <a href="/support/" class="text-white">Support</a>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <div class="relative h-80 md:h-96 w-full overflow-hidden pt-20">
        <img src="/photo2.jpeg" 
             alt="4th Ground Support" 
             class="absolute inset-0 w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 to-black/30"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/50 to-transparent"></div>
        <div class="absolute inset-0 flex items-end">
            <div class="w-full max-w-7xl mx-auto px-6 pb-8 md:pb-10">
                <h1 class="text-4xl md:text-6xl font-bold tracking-tight">Support</h1>
                <p class="text-zinc-300 text-sm md:text-base mt-2">TVOD help for rentals, purchases, and streaming</p>
            </div>
        </div>
    </div>

    <section class="max-w-5xl mx-auto px-6 py-12 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
            
            <!-- Rentals & Purchases -->
            <div class="bg-zinc-900/50 border-zinc-800 rounded-lg p-6 md:p-8 hover:border-zinc-700 transition">
                <div class="flex items-start gap-4">
                    <div class="bg-white/10 p-3 rounded-md">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <h3 class="text-lg font-semibold mb-1">Rentals & Purchases</h3>
                        <p class="text-zinc-400 text-sm mb-3">TVOD windows, 48-hour rentals, purchase access, receipts and refunds</p>
                        <a href="mailto:support@4thground.com" class="text-white hover:text-zinc-300 font-medium break-all">support@4thground.com</a>
                    </div>
                </div>
            </div>

            <!-- Streaming & Playback -->
            <div class="bg-zinc-900/50 border-zinc-800 rounded-lg p-6 md:p-8 hover:border-zinc-700 transition">
                <div class="flex items-start gap-4">
                    <div class="bg-white/10 p-3 rounded-md">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <h3 class="text-lg font-semibold mb-1">Streaming & 4K Playback</h3>
                        <p class="text-zinc-400 text-sm mb-3">Playback issues, buffering, 4K/HD settings, supported devices and browsers</p>
                        <a href="mailto:support@4thground.com" class="text-white hover:text-zinc-300 font-medium break-all">support@4thground.com</a>
                    </div>
                </div>
            </div>

            <!-- Account & Billing -->
            <div class="bg-zinc-900/50 border-zinc-800 rounded-lg p-6 md:p-8 hover:border-zinc-700 transition">
                <div class="flex items-start gap-4">
                    <div class="bg-white/10 p-3 rounded-md">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <h3 class="text-lg font-semibold mb-1">Account & Billing</h3>
                        <p class="text-zinc-400 text-sm mb-3">Login issues, payment methods, invoices, and account changes</p>
                        <a href="mailto:support@4thground.com" class="text-white hover:text-zinc-300 font-medium break-all">support@4thground.com</a>
                    </div>
                </div>
            </div>

            <!-- Pre-Launch & Titles -->
            <div class="bg-zinc-900/50 border-zinc-800 rounded-lg p-6 md:p-8 hover:border-zinc-700 transition">
                <div class="flex items-start gap-4">
                    <div class="bg-white/10 p-3 rounded-md">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <h3 class="text-lg font-semibold mb-1">Pre-Launch & Titles</h3>
                        <p class="text-zinc-400 text-sm mb-3">Early access films, premiere dates, catalog titles, region availability</p>
                        <a href="mailto:support@4thground.com" class="text-white hover:text-zinc-300 font-medium break-all">support@4thground.com</a>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <footer class="border-t border-zinc-800 py-8 text-center text-zinc-500 text-sm">
        <p>© 2026 4TH GROUND. All Rights Reserved.</p>
    </footer>

</body>
</html>
